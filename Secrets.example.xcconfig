// Copy this file to `Secrets.xcconfig` and fill in your Spotify Client ID.
// `Secrets.xcconfig` is gitignored so your Client ID is not committed.
//
// Get a Client ID:
//   1. https://developer.spotify.com/dashboard  ->  Create app
//   2. Redirect URI:  spotifymenubar://callback
//   3. Copy the Client ID below.
//
// (PKCE is used, so there is NO client secret to store.)

SPOTIFY_CLIENT_ID = your_client_id_here
